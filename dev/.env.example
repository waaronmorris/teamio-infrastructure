# TeamIO Local Development Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Database
# =============================================================================
POSTGRES_USER=teamio
POSTGRES_PASSWORD=teamio_dev_password
POSTGRES_DB=teamio

# =============================================================================
# Backend (Rust/Axum)
# =============================================================================
JWT_SECRET=dev_jwt_secret_change_in_production_use_long_random_string
RUST_LOG=info,teamio_backend=debug
CORS_ORIGIN=*
# Stripe (sandbox/test key for payments and pricing)
STRIPE_SECRET_KEY=

# =============================================================================
# Frontend (React/Vite)
# =============================================================================
VITE_API_URL=http://localhost:8082/api
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# =============================================================================
# PostHog Analytics
# =============================================================================
# Project API key (for backend event capture)
POSTHOG_API_KEY=
# Personal API key (for QA agent queries - create at PostHog > Settings > Personal API Keys)
POSTHOG_PERSONAL_API_KEY=
# Project ID (find at PostHog > Settings > Project > Project ID)
POSTHOG_PROJECT_ID=
POSTHOG_HOST=https://us.i.posthog.com

# =============================================================================
# GitHub (for QA agent issue filing)
# =============================================================================
# Personal access token (create at github.com/settings/tokens - needs 'repo' scope)
GH_TOKEN=
GITHUB_REPO=waaronmorris/teamio

# =============================================================================
# Anthropic / Claude (for AI-powered QA analysis)
# =============================================================================
ANTHROPIC_API_KEY=

# =============================================================================
# QA Chaos Agent
# =============================================================================
# Set to "true" to file bugs as GitHub issues
FILE_GITHUB_ISSUES=false
# Dry run - log what would be filed without creating issues
DRY_RUN=false
# Minimum severity to file as GitHub issue: critical, error, warning, info
GITHUB_MIN_SEVERITY=warning
# Max crawl duration in ms (0 = run forever, 300000 = 5 min)
QA_MAX_DURATION=300000
# Max pages to visit per crawl cycle
QA_MAX_PAGES=50
# PostHog reviewer lookback period in hours
LOOKBACK_HOURS=24

# =============================================================================
# Optional Tools
# =============================================================================
PGADMIN_EMAIL=admin@teamio.local
PGADMIN_PASSWORD=admin
