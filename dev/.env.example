# TeamIO Local Development Environment Configuration
# Copy this file to .env and modify as needed

# =============================================================================
# Database Configuration
# =============================================================================
POSTGRES_USER=teamio
POSTGRES_PASSWORD=teamio_dev_password
POSTGRES_DB=teamio

# =============================================================================
# Backend Configuration
# =============================================================================
JWT_SECRET=dev_jwt_secret_change_in_production_use_long_random_string
RUST_LOG=info,teamio_backend=debug

# =============================================================================
# Frontend Configuration
# =============================================================================
VITE_API_URL=http://localhost:8082/api

# =============================================================================
# Optional Tools (pgAdmin)
# =============================================================================
PGADMIN_EMAIL=admin@teamio.local
PGADMIN_PASSWORD=admin
